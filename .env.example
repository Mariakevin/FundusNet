# Django secret key — generate a strong random key for production
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me

# Comma-separated allowed hosts (default: 127.0.0.1,localhost,testserver)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Set to True for production (enables HSTS, CSP, secure cookies)
DJANGO_PRODUCTION=False
